{
  "name": "openlr-lab-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "deploy": "cd ../crates/openlr-wasm && wasm-pack build --target web --out-dir ../../web/src/wasm && cd ../../web && vite build && wrangler pages deploy dist --project-name=openlr-lab"
  },
  "dependencies": {
    "@maptoolkit/maplibre-gl-logo": "^0.1.0",
    "maplibre-gl": "^4",
    "pmtiles": "^3",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4",
    "vite": "^5",
    "wrangler": "^4.112.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
